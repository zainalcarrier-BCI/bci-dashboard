# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Local API used by the frontend during development.
MOCK_API_PORT=4000
VITE_API_BASE_URL="http://localhost:4000"

# Production API hosting usually provides PORT automatically.
# BCI_ALLOWED_ORIGINS should contain the frontend URL(s), separated by commas.
PORT=4000
BCI_ALLOWED_ORIGINS="http://localhost:3000"

# Supabase values will be filled after the real project is created.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Server-only Supabase values used by mock-api/server.mjs.
# Keep this in .env.local only. Never expose service role key to Vite/client code.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
BCI_DEMO_TECH_EMPLOYEE_ID="TCH-001"
BCI_DEMO_MANAGER_EMPLOYEE_ID="ENG-001"
BCI_DEMO_WORK_DATE="2026-04-14"
BCI_SESSION_SECRET="change-this-local-demo-secret"
BCI_ALLOW_ANON_MANAGER_DEMO="false"
