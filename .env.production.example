# BCI Field Service production environment template.
# Do not commit real secrets. Copy these values into the hosting provider's
# environment variable settings.

# Frontend build-time values.
# Use "/api" when frontend and API are deployed together on Vercel.
# Use "https://api.example.com" when API is deployed on a separate service.
VITE_API_BASE_URL="/api"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# API runtime values.
NODE_ENV="production"
PORT=4000
# Use "*" for same-origin Vercel deployment or a comma-separated frontend allowlist
# when API is hosted separately.
BCI_ALLOWED_ORIGINS="*"

# Supabase server-only values. Never expose the service role key to the browser.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Operational defaults.
BCI_DEMO_WORK_DATE="2026-04-14"
BCI_SESSION_SECRET="replace-with-a-long-random-secret"
BCI_ALLOW_ANON_MANAGER_DEMO="false"
